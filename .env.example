# GitHub API
GITHUB_TOKEN=

# DeepSeek API
DEEPSEEK_API_KEY=
DEEPSEEK_API_BASE=https://api.deepseek.com/v1

# Model Configuration
MODEL_NAME=deepseek-chat
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Retry Settings
MAX_RETRIES=3
RETRY_DELAY=1.0

# Chunking Settings
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# Database
DATABASE_URL=sqlite:///./data/self_healing.db

# App
APP_NAME=Self-Healing AI CI/CD Agent
APP_VERSION=0.1.0
DEBUG=false
LOG_LEVEL=INFO
