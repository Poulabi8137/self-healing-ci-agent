# =============================================================================
# Self-Healing AI CI/CD Agent - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env
# =============================================================================

# --- GitHub API --------------------------------------------------------------
# GitHub personal access token with repo scope for PR creation.
# Generate at: https://github.com/settings/tokens
GITHUB_TOKEN=

# --- DeepSeek API ------------------------------------------------------------
# API key for DeepSeek LLM. Get yours at https://platform.deepseek.com
DEEPSEEK_API_KEY=
# API base URL (change for self-hosted or alternative providers)
DEEPSEEK_API_BASE=https://api.deepseek.com/v1

# --- Model Configuration -----------------------------------------------------
# LLM model name
MODEL_NAME=deepseek-chat
# Embedding model for RAG vector search
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- Retry Settings ----------------------------------------------------------
# Maximum number of retry attempts before giving up
MAX_RETRIES=3
# Delay in seconds between retry attempts
RETRY_DELAY=1.0

# --- Chunking Settings -------------------------------------------------------
# Size of code chunks for RAG indexing (in characters)
CHUNK_SIZE=512
# Overlap between consecutive chunks
CHUNK_OVERLAP=50

# --- Database ----------------------------------------------------------------
# SQLite connection string (default: local file)
# For PostgreSQL use: postgresql://user:pass@host:5432/dbname
DATABASE_URL=sqlite:///./data/self_healing.db

# --- Application -------------------------------------------------------------
# Application name (used in API responses and logs)
APP_NAME=Self-Healing AI CI/CD Agent
# Application version
APP_VERSION=0.1.0
# Enable debug mode (reload on code changes, verbose logging)
DEBUG=false
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
