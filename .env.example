# =============================================================================
# Self-Healing AI CI/CD Agent - Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env
# =============================================================================

# --- GitHub API --------------------------------------------------------------
# GitHub personal access token with repo scope for PR creation.
# Generate at: https://github.com/settings/tokens
GITHUB_TOKEN=your_github_token_here

# --- LLM Provider Selection --------------------------------------------------
# Which LLM provider to use: deepseek | groq | openai
LLM_PROVIDER=deepseek
# Model name override (provider-specific default used if not set)
LLM_MODEL=deepseek-chat

# --- DeepSeek API ------------------------------------------------------------
# API key for DeepSeek LLM. Get yours at https://platform.deepseek.com
DEEPSEEK_API_KEY=your_deepseek_api_key_here
# API base URL (change for self-hosted or alternative providers)
DEEPSEEK_API_BASE=https://api.deepseek.com/v1

# --- Groq API ----------------------------------------------------------------
# API key for Groq. Get yours at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
# Groq model (default: deepseek-r1-distill-llama-70b)
GROQ_MODEL=deepseek-r1-distill-llama-70b

# --- Model Configuration -----------------------------------------------------
# LLM model name (fallback for deepseek provider)
MODEL_NAME=deepseek-chat
# Embedding model for RAG vector search
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- Retry Settings ----------------------------------------------------------
# Maximum number of retry attempts before giving up
MAX_RETRIES=3
# Base delay in seconds between retry attempts
RETRY_DELAY=1.0
# Exponential backoff multiplier (delay * backoff_factor^(attempt-1))
RETRY_BACKOFF_FACTOR=2.0
# Random jitter fraction (+/-) added to each delay
RETRY_JITTER=0.1

# --- Chunking Settings -------------------------------------------------------
# Size of code chunks for RAG indexing (in characters)
CHUNK_SIZE=512
# Overlap between consecutive chunks
CHUNK_OVERLAP=50

# --- Database ----------------------------------------------------------------
# SQLite connection string (default: local file)
# For PostgreSQL use: postgresql://user:pass@host:5432/dbname
DATABASE_URL=sqlite:///./data/self_healing.db

# --- Application -------------------------------------------------------------
# Application name (used in API responses and logs)
APP_NAME=Self-Healing AI CI/CD Agent
# Application version
APP_VERSION=1.0.0
# Enable debug mode (reload on code changes, verbose logging)
DEBUG=false
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
# Enable structured JSON logging (write app.jsonl in log directory)
LOG_JSON=false

# --- Auth --------------------------------------------------------------------
# Enable API key authentication (set to false for development only)
AUTH_ENABLED=true
# Pre-shared admin API key for first-time setup
BOOTSTRAP_ADMIN_KEY=your_admin_key_here

# --- Rate Limiting -----------------------------------------------------------
# Enable rate limiting middleware
RATE_LIMITING_ENABLED=true
# Default requests per window (used if no per-route limit is defined)
RATE_LIMIT_DEFAULT=30
# Rate limit window in seconds
RATE_LIMIT_WINDOW=60

# --- Deployment --------------------------------------------------------------
# Number of gunicorn worker processes (production: 2-4 per CPU core)
WORKERS=4
# Comma-separated allowed CORS origins (set to specific origin in production)
#   Development: CORS_ORIGINS=*
#   Production:  CORS_ORIGINS=https://app.example.com
CORS_ORIGINS=*

# --- Circuit Breaker ---------------------------------------------------------
# Consecutive failures before circuit opens
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
# Seconds before attempting recovery (OPEN -> HALF_OPEN)
CIRCUIT_BREAKER_RECOVERY_TIMEOUT=30
# Successful requests needed in HALF_OPEN to close the circuit
CIRCUIT_BREAKER_HALF_OPEN_MAX_REQUESTS=3
